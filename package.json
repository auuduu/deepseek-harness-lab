{
  "name": "deepseek-harness-lab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A local coding-agent harness MVP for repo scanning, DeepSeek planning, automatic patching, trace capture, and dashboard review.",
  "bin": {
    "harness-lab": "dist/cli/index.js"
  },
  "scripts": {
    "dev": "concurrently \"npm:api\" \"npm:web\"",
    "api": "tsx src/server/index.ts",
    "web": "vite --host 127.0.0.1",
    "harness": "tsx src/cli/index.ts",
    "build": "tsc -p tsconfig.json && vite build",
    "start": "node dist/server/index.js",
    "test": "vitest run tests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "commander": "^14.0.2",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "vite": "^7.2.7",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  },
  "engines": {
    "node": ">=20"
  }
}
